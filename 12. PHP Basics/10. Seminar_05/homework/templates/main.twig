{% extends 'layout.twig' %}

{% block title %}Главная страница{% endblock %}

{% block content %}
    <h2>🏠 Управление пользователями</h2>
    
    <!-- Форма добавления -->
    <form action="/user/save/" method="GET" style="background: #f9f9f9; padding: 20px; border-radius: 5px; border: 1px solid #ddd; max-width: 400px; color: #333; margin-bottom: 30px;">
        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px; font-weight: bold;">Имя:</label>
            <input type="text" name="name" placeholder="Например, Иван" required style="width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px;">
        </div>
        
        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px; font-weight: bold;">Дата рождения:</label>
            <input type="text" name="birthday" placeholder="ДД-ММ-ГГГГ" required style="width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px;">
        </div>
        
        <button type="submit" style="background: #2ecc71; color: white; border: none; padding: 10px 15px; border-radius: 4px; font-weight: bold; cursor: pointer; width: 100%;">
            💾 Сохранить в базу
        </button>
    </form>

    <!-- Список сохраненных пользователей -->
    <h3>👥 Список пользователей в базе данных</h3>
    
    {% if users is not empty %}
        <table style="width: 100%; border-collapse: collapse; background: white; color: #333; border-radius: 4px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <thead>
                <tr style="background: #34495e; color: white; text-align: left;">
                    <th style="padding: 10px 15px;">Имя</th>
                    <th style="padding: 10px 15px;">Дата рождения</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr style="border-bottom: 1px solid #ddd;">
                        <td style="padding: 10px 15px;">{{ user.name }}</td>
                        <td style="padding: 10px 15px;">{{ user.birthday }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p style="background: #eef2f5; padding: 15px; border-radius: 4px; color: #666;">База данных пока пуста. Добавьте первого пользователя!</p>
    {% endif %}

{% endblock %}
