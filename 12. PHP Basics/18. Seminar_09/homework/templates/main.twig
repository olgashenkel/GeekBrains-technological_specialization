{% extends 'layout.twig' %}
{% block content %}
    
    <div style="display: flex; gap: 40px;">
        <!-- ФОРМА CRUD -->
        <div style="background: white; padding: 20px; border-radius: 6px; width: 350px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); height: fit-content;">
            <h3>{{ edit_user ? '🔄 Обновить данные' : '➕ Добавить пользователя' }}</h3>
            <form action="/user/save" method="POST">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                {% if edit_user %}<input type="hidden" name="id" value="{{ edit_user.id_user }}">{% endif %}
                <p>Имя:<br><input type="text" name="name" value="{{ edit_user.user_name }}" required style="width:100%; padding:6px;"></p>
                <p>Фамилия:<br><input type="text" name="lastname" value="{{ edit_user.user_lastname }}" required style="width:100%; padding:6px;"></p>
                <p>Дата рождения:<br><input type="text" name="birthday" value="{{ birthday_str }}" placeholder="ДД-ММ-ГГГГ" required style="width:100%; padding:6px;"></p>
                <p>Логин для входа:<br><input type="text" name="login" value="{{ edit_user.login }}" placeholder="Логин" required style="width:100%; padding:6px;"></p>
                
                <p>Пароль:<br>
                    <input type="password" name="password" placeholder="Пароль" required style="width:100%; padding:6px;">
                    <small style="color:#7f8c8d; font-size:11px; display:block; margin-top:4px;">* 8-16 симв, 1 цифра, 1 заглавная, 1 строчная, 1 спецсимвол.</small>
                </p>
                
                <button type="submit" style="background:#2ecc71; color:white; border:none; padding:10px; width:100%; cursor:pointer; font-weight:bold; border-radius:4px;">Сохранить</button>
            </form>
        </div>

        <!-- ТАБЛИЦА С ВЫВОДОМ СУММЫ ОПЛАТ -->
        <div style="flex: 1; background: white; padding: 20px; border-radius: 6px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
            <h3>👥 Список пользователей и баланс</h3>
            <table border="1" cellpadding="8" style="width: 100%; border-collapse: collapse; text-align: left;">
                <tr style="background: #eee;"><th>ID</th><th>Имя</th><th>Фамилия</th><th>Логин</th><th>Сумма оплат</th><th>Действия</th></tr>
                {% for user in users %}
                    <!-- КРИТИЧЕСКИ ВАЖНО: Проверьте, чтобы у tr был этот id! -->
                    <tr id="user-row-{{ user.id_user }}">
                        <td>{{ user.id_user }}</td>
                        <td>{{ user.user_name }}</td>
                        <td>{{ user.user_lastname }}</td>
                        <td>{{ user.login ? user.login : '<span style="color:#aaa;">нет</span>' }}</td>
                        <td style="color:#27ae60; font-weight:bold;">{{ user.total_paid }} руб.</td>
                        <td>
                            {% if is_admin %}
                                <a href="/?edit_id={{ user.id_user }}" style="color: #3498db; text-decoration: none; font-weight:bold;">[ Редактировать ]</a>
                                <!-- ИСПРАВЛЕНО: Добавили нативный вызов onclick -->
                                <a href="#" onclick="deleteUserAsync(event, {{ user.id_user }})" style="color: #e74c3c; margin-left: 15px; text-decoration: none; font-weight:bold;">[ Удалить AJAX ]</a>
                            {% else %}
                                <span style="color: #7f8c8d; font-style: italic;">Доступ ограничен</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </table>
        </div>
    </div>

    <!-- НАДЕЖНЫЙ СКРИПТ НА ЧИСТОМ JAVASCRIPT (БЕЗ JQUERY) -->
    <script>
    function deleteUserAsync(event, userId) {
        event.preventDefault(); // Блокируем перезагрузку страницы
        
        if (!confirm('Удалить этого пользователя асинхронно?')) {
            return;
        }

        // Формируем POST-данные (FormData)
        let formData = new FormData();
        formData.append('id', userId);

        // Отправляем асинхронный запрос через встроенный fetch()
        fetch('/user/delete-async', {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest' // Помечаем как AJAX запрос
            }
        })
        .then(response => response.json()) // Парсим JSON от сервера
        .then(data => {
            if (data.success) {
                // Находим строку таблицы
                let row = document.getElementById('user-row-' + userId);
                if (row) {
                    // Анимация плавного растворения на чистом CSS
                    row.style.transition = 'opacity 0.4s ease';
                    row.style.opacity = '0';
                    setTimeout(() => {
                        row.remove(); // Полностью удаляем строку из HTML
                    }, 400);
                }
            } else {
                alert('Ошибка сервера: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Сетевая ошибка при удалении. Проверьте консоль F12.');
        });
    }
    </script>
{% endblock %}
